{
  "version": 2,
  "functions": {
    "api/userinfo.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/userinfo.json",
      "dest": "/api/userinfo.js"
    },
    {
      "src": "/",
      "dest": "/api/userinfo.js"
    },
    {
      "src": "/api/userinfo",
      "dest": "/api/userinfo.js"
    }
  ],
  "headers": [
    {
      "source": "/userinfo.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
